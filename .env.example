# Supabase project settings (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Single-user allow-list. Sign-in is rejected for any other email.
ALLOWED_USER_EMAIL=you@example.com

# Anthropic API (server-side only, used by /api/triage) - OPTIONAL.
# Leave unset (or a placeholder) and triage runs on a free, built-in
# keyword-heuristic fallback (src/lib/triageFallback.ts) - no cost, no
# network call. Set a real key to transparently upgrade to real Claude
# triage; unset it again to fall back to the heuristic at any time.
ANTHROPIC_API_KEY=sk-ant-your-key

# Public site URL, used to build deep links in push notifications - phase 9
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Web Push VAPID keys (generate with `npx web-push generate-vapid-keys`) - phase 9
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Shared secret required by Vercel Cron routes
CRON_SECRET=change-me
