# Supabase project settings (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Single-user allow-list. Sign-in is rejected for any other email.
ALLOWED_USER_EMAIL=you@example.com

# Anthropic API (server-side only, used by /api/triage)
ANTHROPIC_API_KEY=sk-ant-your-key

# Resend (outbound daily digest email) - phase 9
RESEND_API_KEY=re_your-key

# Inbound email webhook shared secret - phase 10
INBOUND_EMAIL_SECRET=change-me

# Web Push VAPID keys (generate with `npx web-push generate-vapid-keys`) - phase 9
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Shared secret required by Vercel Cron routes
CRON_SECRET=change-me
